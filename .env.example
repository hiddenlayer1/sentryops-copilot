# Live Splunk backend — point the agent at a real Splunk MCP Server at runtime.
#
#   1. Start the bundled MCP server against your Splunk management port:
#        SPLUNK_REST_URL=https://localhost:8089 python server/splunk_mcp_server.py --port 8765
#   2. Set the two values below, then:  python connect_check.py
#   3. Run the live agent:              python demo/run_demo.py
#
# Without these set, the demo and tests run fully offline on the synthetic incident.

SPLUNK_MCP_URL=http://127.0.0.1:8765/mcp
SPLUNK_MCP_TOKEN=<splunk bearer token>

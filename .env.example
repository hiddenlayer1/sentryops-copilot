# Live Splunk backend (optional — the demo runs without any of this).
# Provision a Splunk Enterprise Trial (60d) or Cloud + Developer License (6mo),
# install the Splunk MCP Server (Splunkbase app 7931) on the Search Head, and
# grant the mcp_tool_execute capability. Then:
#
#   cp .env.example .env  &&  set the two values  &&  python connect_check.py
#
SPLUNK_MCP_URL=https://<your-search-head>:8089/services/mcp
SPLUNK_MCP_TOKEN=<splunk bearer token with mcp_tool_execute>
